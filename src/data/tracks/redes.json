{
  "id": "redes",
  "name": "Networking",
  "icon": "🌐",
  "color": "#a855f7",
  "tagline": "OSI ao CCNA — base de tudo",
  "estimated_hours": 100,
  "source_courses": ["Cisco NetAcad", "Jeremy IT Lab CCNA"],
  "prereqs": [],
  "feeds_certs": ["ccna", "secplus", "ejpt", "awssaa", "cka"],
  "phase_relevance": ["fase1", "fase2"],
  "modules": [
    {
      "id": "redes.1",
      "name": "Fundamentos TCP/IP",
      "estimated_minutes": 240,
      "topics": [
        { "id": "redes.1.1", "name": "Modelo OSI vs TCP/IP", "minutes": 30 },
        { "id": "redes.1.2", "name": "Encapsulamento e PDUs", "minutes": 30 },
        { "id": "redes.1.3", "name": "IPv4 — endereçamento, classes, CIDR", "minutes": 60 },
        { "id": "redes.1.4", "name": "Subnetting na prática", "minutes": 90 },
        { "id": "redes.1.5", "name": "IPv6 essencial", "minutes": 30 }
      ],
      "exercises": [
        { "id": "ex.redes.1.a", "name": "20 exercícios subnet.ipxchallenge.com", "type": "drill" },
        { "id": "ex.redes.1.b", "name": "Subnetting VLSM em papel", "type": "drill" }
      ],
      "checkpoint": "Calcular subnet, broadcast, range de hosts em <30s mentalmente."
    },
    {
      "id": "redes.2",
      "name": "Camada de Transporte e Aplicação",
      "estimated_minutes": 240,
      "topics": [
        { "id": "redes.2.1", "name": "TCP — 3-way handshake, flags, window", "minutes": 60 },
        { "id": "redes.2.2", "name": "UDP — quando e por quê", "minutes": 30 },
        { "id": "redes.2.3", "name": "Portas well-known e ephemeral", "minutes": 30 },
        { "id": "redes.2.4", "name": "DNS — resolução, registros, DoH/DoT", "minutes": 60 },
        { "id": "redes.2.5", "name": "HTTP/HTTPS — métodos, status, headers", "minutes": 30 },
        { "id": "redes.2.6", "name": "TLS handshake e certificados", "minutes": 30 }
      ],
      "exercises": [
        { "id": "ex.redes.2.a", "name": "Captura tcpdump de handshake TCP completo", "type": "lab" },
        { "id": "ex.redes.2.b", "name": "Inspecionar TLS handshake com Wireshark", "type": "lab" }
      ],
      "checkpoint": "Traçar packet por packet o que acontece de digitar URL até página renderizar."
    },
    {
      "id": "redes.3",
      "name": "Roteamento e Switching",
      "estimated_minutes": 300,
      "topics": [
        { "id": "redes.3.1", "name": "Switches L2 — MAC table, broadcast domain", "minutes": 30 },
        { "id": "redes.3.2", "name": "VLANs e trunking (802.1Q)", "minutes": 60 },
        { "id": "redes.3.3", "name": "Spanning Tree Protocol", "minutes": 45 },
        { "id": "redes.3.4", "name": "Roteamento estático", "minutes": 30 },
        { "id": "redes.3.5", "name": "OSPF essencial", "minutes": 60 },
        { "id": "redes.3.6", "name": "BGP — visão geral", "minutes": 30 },
        { "id": "redes.3.7", "name": "NAT/PAT", "minutes": 45 }
      ],
      "exercises": [
        { "id": "ex.redes.3.a", "name": "Lab Packet Tracer: 3 VLANs + roteamento inter-VLAN", "type": "lab" },
        { "id": "ex.redes.3.b", "name": "Lab OSPF multi-area no GNS3", "type": "lab" }
      ],
      "checkpoint": "Topologia funcional com VLANs, OSPF e NAT no Packet Tracer."
    },
    {
      "id": "redes.4",
      "name": "Segurança de Redes",
      "estimated_minutes": 240,
      "topics": [
        { "id": "redes.4.1", "name": "Firewalls — stateful vs stateless", "minutes": 45 },
        { "id": "redes.4.2", "name": "ACLs em roteador", "minutes": 45 },
        { "id": "redes.4.3", "name": "VPN site-to-site e remote access", "minutes": 45 },
        { "id": "redes.4.4", "name": "IDS/IPS — Snort, Suricata", "minutes": 45 },
        { "id": "redes.4.5", "name": "Ataques (ARP poisoning, DNS spoofing, MITM)", "minutes": 60 }
      ],
      "exercises": [
        { "id": "ex.redes.4.a", "name": "ACL extended bloqueando porta 23 mas permitindo 22", "type": "lab" },
        { "id": "ex.redes.4.b", "name": "Lab ARP poisoning + detecção", "type": "lab" }
      ],
      "checkpoint": "Pentest básico de rede local: scan, identificação, exploração controlada."
    },
    {
      "id": "redes.5",
      "name": "Wireless e Cloud Networking",
      "estimated_minutes": 180,
      "topics": [
        { "id": "redes.5.1", "name": "Wi-Fi — 802.11, canais, segurança WPA", "minutes": 45 },
        { "id": "redes.5.2", "name": "VPC (AWS), VNET (Azure)", "minutes": 60 },
        { "id": "redes.5.3", "name": "SDN e overlay networks", "minutes": 30 },
        { "id": "redes.5.4", "name": "CDN e load balancers", "minutes": 45 }
      ],
      "exercises": [
        { "id": "ex.redes.5.a", "name": "Desenhar VPC AWS com 2 AZs, public+private subnets", "type": "design" }
      ],
      "checkpoint": "Arquitetura completa de rede AWS production-ready desenhada."
    }
  ],
  "projects": [
    {
      "id": "proj.redes.1",
      "name": "🌐 Network Mapper em C",
      "level": "portfolio",
      "tags": ["C", "Redes", "EDA"],
      "description": "Scanner de hosts em C usando lista encadeada, detecta portas abertas, banner grabbing, gera relatório.",
      "consumes_modules": ["redes.1", "redes.2", "redes.4"],
      "deliverables": ["Repo público", "Build com Makefile", "Demo em vídeo"]
    }
  ]
}
