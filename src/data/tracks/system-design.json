        { "id": "sd.3.5", "name": "ACID vs BASE", "minutes": 30 },
        { "id": "sd.3.6", "name": "Quorum (R + W > N)", "minutes": 30 },
        { "id": "sd.3.7", "name": "SQL vs NoSQL — quando escolher cada", "minutes": 45 },
        { "id": "sd.3.8", "name": "Distributed transactions, 2PC, Saga", "minutes": 30 }
