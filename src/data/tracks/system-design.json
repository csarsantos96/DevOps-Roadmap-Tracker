        { "id": "sd.2.2", "name": "Reverse proxy (nginx, HAProxy)", "minutes": 30 },
        { "id": "sd.2.3", "name": "Caching (LRU, TTL, write-through, write-back)", "minutes": 60 },
        { "id": "sd.2.4", "name": "CDN — edge caching", "minutes": 30 },
        { "id": "sd.2.5", "name": "Message Queues (Kafka, RabbitMQ, SQS)", "minutes": 60 },
        { "id": "sd.2.6", "name": "Pub/Sub patterns", "minutes": 45 },
        { "id": "sd.2.7", "name": "Event-driven architecture", "minutes": 45 },
        { "id": "sd.2.8", "name": "Rate limiting (token bucket, leaky bucket)", "minutes": 30 }
