    {
      "id": "sd.1",
      "name": "Fundamentos de Sistemas Distribuídos",
      "estimated_minutes": 360,
      "topics": [
        { "id": "sd.1.1", "name": "Cliente-servidor, monolito vs microsserviços", "minutes": 45 },
        { "id": "sd.1.2", "name": "CAP Theorem (Consistência, Disponibilidade, Partition)", "minutes": 60 },
        { "id": "sd.1.3", "name": "PACELC e trade-offs reais", "minutes": 30 },
        { "id": "sd.1.4", "name": "Latência vs Throughput", "minutes": 30 },
        { "id": "sd.1.5", "name": "Vertical vs Horizontal scaling", "minutes": 30 },
        { "id": "sd.1.6", "name": "Stateless vs Stateful services", "minutes": 30 },
        { "id": "sd.1.7", "name": "Consistency models (eventual, strong, causal)", "minutes": 60 },
        { "id": "sd.1.8", "name": "Idempotência e retries", "minutes": 45 },
        { "id": "sd.1.9", "name": "Back-of-envelope estimation", "minutes": 30 }
      ],
      "exercises": [
        { "id": "ex.sd.1.a", "name": "Estimar QPS e storage do Twitter (back-of-envelope)", "type": "design" },
        { "id": "ex.sd.1.b", "name": "Desenhar CAP trade-offs do Cassandra vs Postgres", "type": "design" }
      ],
      "checkpoint": "Explicar Feynman: por que sistemas distribuídos sacrificam consistência?"
    },
